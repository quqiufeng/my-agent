# AutoBot 环境配置示例
# 复制此文件为 .env 并填入实际值

# ============ 钉钉 WebSocket Stream 凭证 ============
# 从钉钉开放平台获取: https://open.dingtalk.com/
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# ============ 硅基流动 API ============
# API Key (从 https://cloud.siliconflow.cn 获取)
API_KEY=

# 模型 key (可选，默认 kimi-k2.5)
# 可用模型 key:
#   - 对话模型: deepseek-v3.2, deepseek-r1, qwen2-72b, qwq-32b, glm-5, glm-4
#   - 视觉模型: kimi-k2.5, kimi-k2, qwen2-vl-72b, deepseek-vl2, glm-4v
#   - 图像模型: kolors, flux1-schnell, flux1-dev
#   - 免费模型: qwen2.5-7b-free, qwen1.5-7b-free, glm4-9b-free
MODEL=kimi-k2.5

# ============ 工作目录 ============
# AutoBot 工作目录
WORK_DIR=/mnt/e/app/my-game

# GitHub 仓库地址（AI 会读取此项目代码）
GITHUB_REPO=https://github.com/quqiufeng/my-game

# 代理配置（可选，用于安装包或外网访问）
HTTP_PROXY=
HTTPS_PROXY=

# 沙盒安全目录（Python 代码只能在此目录内操作）
SANDBOX_DIR=/mnt/e/app/my-game

# ============ 执行配置 ============
# 最大步数限制
MAX_STEPS=20

# 命令超时秒数
TIMEOUT=300
